@{
    ViewData["Title"] = "Contact ABC Retail";
}

<div class="container mt-5">
    <h1>Contact Us</h1>
    <p class="lead">Have questions or feedback? Reach out to our support team.</p>

    <div class="row mt-4">
        <div class="col-md-6">
            <form asp-action="Contact" method="post">
                <div class="mb-3">
                    <label for="Name" class="form-label">Full Name</label>
                    <input type="text" class="form-control" id="Name" name="Name" required>
                </div>

                <div class="mb-3">
                    <label for="Email" class="form-label">Email Address</label>
                    <input type="email" class="form-control" id="Email" name="Email" required>
                </div>

                <div class="mb-3">
                    <label for="Message" class="form-label">Message</label>
                    <textarea class="form-control" id="Message" name="Message" rows="5" required></textarea>
                </div>

                <button type="submit" class="btn btn-primary">Send Message</button>
            </form>
        </div>

        <div class="col-md-6">
            <h4>Our Office</h4>
            <p>ABC Retail HQ<br>123 Cloud Avenue, Tech City, South Africa</p>
            <p>Email: support@abcretail.co.za<br>Phone: +27 11 555 1234</p>

        </div>
    </div>
</div>